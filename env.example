# Environment Variables Template
# Copy this file to .env and fill in all values before running docker-compose
# NEVER commit .env to any repository

# ============================================================
# SERVER
# ============================================================
NODE_ENV=production

# ============================================================
# TELEGRAM ALERTS
# Used by: Uptime Kuma, Fail2ban, Node.js health checks
# How to get: Create a bot via @BotFather on Telegram
#             Get your chat ID via @userinfobot on Telegram
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# ANALYTICS — UMAMI
# Used by: All frontend pages
# UMAMI_APP_SECRET: Generate a random 32-character string
# UMAMI_SITE_ID: Generated after Umami setup — add after first login
# ============================================================
UMAMI_APP_SECRET=
UMAMI_SITE_ID=

# ============================================================
# MONETIZATION — PROPELLERADS
# Used by: TikTok downloader page, Twitter downloader page
# How to get: Sign up at propellerads.com, create two ad zones
# ============================================================
PROPELLERADS_ZONE_TIKTOK=
PROPELLERADS_ZONE_TWITTER=

# ============================================================
# MONETIZATION — ADSENSE
# Used by: Invoice generator, AI detector, AI humanizer, Paystub generator
# How to get: Apply at google.com/adsense after 2 weeks of traffic
# Format: pub-XXXXXXXXXXXXXXXXX
# ============================================================
ADSENSE_PUBLISHER_ID=

# ============================================================
# AI API — GOOGLE GEMINI (free tier)
# Used by: AI Humanizer tool (backend only, never exposed to frontend)
# Model used: gemini-2.0-flash
# Get key at: aistudio.google.com/apikey
# Future: replace with self-hosted Ollama API
# ============================================================
GEMINI_API_KEY=

# ============================================================
# MONITORING — IP ALLOWLIST
# Used by: Nginx to restrict access to monitoring dashboards
# Value: Your public IP address
# Dashboards: monitor.aawebtools.com, netdata.aawebtools.com, analytics.aawebtools.com
# ============================================================
OWNER_IP=

# ============================================================
# DATABASE — UMAMI POSTGRES
# These are internal — only change if you have a conflict
# ============================================================
UMAMI_DB_PASSWORD=change_this_to_random_string
