#!/usr/bin/env bash
# Pre-commit hook for aawebtools.com
#
# Runs the strict translate-pipeline validator before allowing a commit.
# Refuses commits that would introduce new pages failing the 14 checks
# defined in tools/translate/lib/validator.js — including silent section
# drops, broken hreflang, ASCII-stripped diacritics, phantom ja_JP refs,
# Hinglish, and thin word counts.
#
# Install once per clone:
#   git config core.hooksPath scripts/git-hooks
#
# Bypass (only if you know what you're doing):
#   git commit --no-verify

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Only run if pipeline-relevant files are staged. This keeps trivial
# commits (docs, configs) fast.
RELEVANT_FILES=$(git diff --cached --name-only --diff-filter=ACMR | \
    grep -E '^(frontend/|tools/translate/|package\.json)' || true)

if [ -z "$RELEVANT_FILES" ]; then
    exit 0
fi

echo "[pre-commit] Running translate pipeline validator..."

if ! command -v node >/dev/null 2>&1; then
    echo "[pre-commit] WARNING: node not found, skipping validation"
    exit 0
fi

# Run the validator. It exits non-zero on:
#   - page-map.json schema/uniqueness violations (exit 2)
#   - any localized page failing 14 strict checks (exit 1)
if ! node tools/translate/build.js > /tmp/aawebtools-precommit.log 2>&1; then
    echo "[pre-commit] ✗ Pipeline validation failed:"
    tail -30 /tmp/aawebtools-precommit.log
    echo ""
    echo "Fix the failures above, or run with --no-verify if intentional."
    echo "Full log: /tmp/aawebtools-precommit.log"
    exit 1
fi

# Check the summary line for any failures (the validator currently runs
# even when no relevant files changed via the path filter above; this
# additional grep guards against future regressions where the validator
# might exit 0 with failures).
if grep -q "0 failed" /tmp/aawebtools-precommit.log; then
    echo "[pre-commit] ✓ Validator passed"
else
    grep "Summary:" /tmp/aawebtools-precommit.log || true
    echo "[pre-commit] WARNING: validator reported failures but exited 0"
    echo "             this is a pre-existing baseline; the strategic decision"
    echo "             to fix vs quarantine is documented in docs/SEO_RECOVERY.md"
fi

exit 0
